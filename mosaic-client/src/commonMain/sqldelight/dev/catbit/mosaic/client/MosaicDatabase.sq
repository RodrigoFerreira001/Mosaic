CREATE TABLE globalData (
    dataId TEXT NOT NULL PRIMARY KEY,
    data TEXT NOT NULL
);

CREATE TABLE segmentedData (
    segmentId TEXT NOT NULL,
    dataId TEXT NOT NULL,
    data TEXT NOT NULL,
    PRIMARY KEY (segmentId, dataId)
);

setGlobal:
INSERT OR REPLACE INTO globalData(dataId, data)
VALUES (?, ?);

getGlobal:
SELECT data
FROM globalData
WHERE dataId = ?;

deleteGlobal:
DELETE FROM globalData
WHERE dataId = ?;

setSegmented:
INSERT OR REPLACE INTO segmentedData(segmentId, dataId, data)
VALUES (?, ?, ?);

getSegmented:
SELECT data
FROM segmentedData
WHERE segmentId = ? AND dataId = ?;

deleteSegmentedItem:
DELETE FROM segmentedData
WHERE segmentId = ? AND dataId = ?;

deleteSegment:
DELETE FROM segmentedData
WHERE segmentId = ?;